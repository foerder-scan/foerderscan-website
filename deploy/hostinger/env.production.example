# FörderScan – Produktions-Umgebungsvariablen
# Kopieren nach: /var/www/foerderscan/foerderscan/.env.production
# NIEMALS in Git committen!

# ── Datenbank (Neon PostgreSQL) ────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/foerderscan?sslmode=require"

# ── NextAuth ───────────────────────────────────────────
NEXTAUTH_SECRET="min-32-zeichen-zufallsstring-hier"
NEXTAUTH_URL="https://foerderscan.de"

# ── App URL ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://foerderscan.de"

# ── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ── Resend (E-Mail) ────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@foerderscan.de"

# ── Node ───────────────────────────────────────────────
NODE_ENV="production"
PORT=3000
